{
  // Zed settings
  //
  // For information on how to configure Zed, see the Zed//zed.dev/docs/configuring-zed
  //
  // To see all of Zed's default settings without changing your
  // custom settings, run the `open default settings` command
  // from the command palette or from `Zed` application menu.
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "tree_view": true,
    "dock": "left"
  },
  "theme": "One Dark - Darkened",
  "buffer_font_features": {
    "calt": false,
  },
  "icon_theme": {
    "mode": "light",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme",
  },
  "agent_buffer_font_size": 13.0,
  "ui_font_family": ".SystemUIFont",
  "buffer_line_height": "comfortable",
  "agent_ui_font_size": 15.0,
  "edit_predictions": {
    "open_ai_compatible_api": {
      "max_output_tokens": 64,
      "prompt_format": "qwen",
      // "prompt_format": "star_coder",
      "api_url": "http://127.0.0.1:1234/v1/completions",
      "model": "qwen2.5-coder-3b",
      // "model": "starcoder2-7b",
    },
    "mode": "eager",
    "ollama": {
      "prompt_format": "qwen",
      "api_url": "http://127.0.0.1:11434",
      "max_output_tokens": 64,
      "model": "qwen2.5-coder:7b",
    },
    "provider": "open_ai_compatible_api",
  },
  "agent_servers": {
    "gemini": {
      "type": "registry",
    },
    "opencode": {
      "favorite_config_option_values": {
        "model": [
          "anthropic/claude-sonnet-4-7/high",
          "openai/gpt-5.4/high",
          "anthropic/claude-opus-4-7/high"
        ],
      },
      "default_model": "openai/gpt-5.4/high",
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
  },
  "tab_size": 4,
  "vim": {
    "use_system_clipboard": "never",
    "toggle_relative_line_numbers": false,
  },
  "disable_ai": false,
  "base_keymap": "JetBrains",
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "default_profile": "ask",
    "favorite_models": [
      {
        "provider": "openai",
        "model": "gpt-5.4/high",
        // "provider": "lmstudio",
        //"model": "qwen/qwen3-coder-30b",
        // "model": "qwen3-coder-next",
      },
    ],
    "inline_assistant_model": {
      "provider": "openai",
      "model": "gpt-5.4/high",
      // "provider": "lmstudio",
      //"model": "qwen/qwen3-coder-30b",
      // "model": "qwen3-coder-next",
    },
    "default_model": {
      "provider": "openai",
      "model": "gpt-5.4/high",
      // "provider": "lmstudio",
      //"model": "qwen/qwen3-coder-30b",
      // "model": "qwen3-coder-next",
    },
  },
  "ui_font_size": 15.0,
  "buffer_font_family": "KMaple Mono NF",
  "buffer_font_size": 13.0,
  "vim_mode": true,
  "terminal": {
    "alternate_scroll": "off",
    "option_as_meta": false,
    "toolbar": {
      "breadcrumbs": true,
    },
    "shell": "system",
    "line_height": "standard",
    "detect_venv": "off",
  },
  "lsp": {
    "rust-analyzer": {
      "check": {
        "command": "check",
      },
    },
    "cargo-tom": {
      "initialization_options": {
        /// Search
        "per_page": 25,
        /// What features should be displayed on hover
        /// All, UnusedOpt, Features,
        "feature_display_mode": "UnusedOpt",
        "hide_docs_info_message": false,
        /// Sort toml on format
        "sort_format": true,
        /// Use stable versions in completions
        "stable_version": true,
        /// Offline mode uses https://github.com/frederik-uni/crates.io-dump-minfied for search
        /// The order is non existent feel free to contribute
        "offline": false,
      },
    },
    "metals": {
      "settings": {
        "javaHome": "/Users/ben.jeong1/.local/share/mise/installs/java/zulu-21/zulu-21.jdk/Contents/Home",
        "inlayHints": {
          "inferredTypes": {
            "enable": true,
          },
        },
      },
    },
  },
}
