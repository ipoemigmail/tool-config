// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
    "cli_default_open_behavior": "new_window",
    "agent_buffer_font_size": 13.0,
    "buffer_font_size": 13.0,
    "ui_font_size": 15.0,
    "agent_ui_font_size": 15.0,
    "ui_font_family": ".SystemUIFont",
    "outline_panel": {
        "dock": "left",
    },
    "collaboration_panel": {
        "dock": "left",
    },
    "git_panel": {
        "dock": "left",
        "show_count_badge": true,
        "file_icons": false,
        "tree_view": true,
        "status_style": "icon",
    },
    "project_panel": {
        "dock": "left",
        "git_status_indicator": true,
        "hide_gitignore": false,
    },
    "buffer_font_features": {
        "calt": false,
    },
    "buffer_line_height": "comfortable",
    "icon_theme": {
        "mode": "dark",
        "light": "Material Icon Theme",
        "dark": "Material Icon Theme",
    },
    "edit_predictions": {
        "open_ai_compatible_api": {
            "max_output_tokens": 64,
            "model": "qwen2.5-coder-3b",
            "prompt_format": "qwen",
            "api_url": "http://localhost:1234/v1/completions",
        },
        "provider": "open_ai_compatible_api",
        "mode": "eager",
    },
    "agent_servers": {
        "gemini": {
            "type": "registry",
        },
        "claude-acp": {
            "type": "registry",
        },
        "codex-acp": {
            "type": "registry",
            "favorite_models": ["gpt-5.3-codex/medium"],
        },
        "opencode": {
            "favorite_config_option_values": {
                "model": [
                    "anthropic/claude-opus-4-7/high",
                    "openai/gpt-5.5/high",
                ],
            },
            "favorite_models": [
                "anthropic/claude-opus-4-7/high",
                "openai/gpt-5.5/high",
            ],
            "type": "registry",
            "default_model": "openai/gpt-5.5/high",
        },
    },
    "tab_size": 4,
    "vim": {
        "use_system_clipboard": "never",
        "toggle_relative_line_numbers": false,
    },
    "disable_ai": false,
    "base_keymap": "JetBrains",
    "agent": {
        "sidebar_side": "right",
        "dock": "right",
        "favorite_models": [
            {
                "provider": "lmstudio",
                "model": "qwen/qwen3-coder-30b",
            },
        ],
        "inline_assistant_model": {
            "provider": "lmstudio",
            "model": "qwen/qwen3-coder-30b",
        },
        "default_model": {
            "provider": "lmstudio",
            "model": "google/gemma-4-26b-a4b",
        },
    },
    "theme": {
        "mode": "dark",
        "light": "One Light",
        "dark": "One Dark - Darkened",
    },
    "buffer_font_family": "KMaple Mono NF",
    "vim_mode": true,
    "terminal": {
        "font_size": 13.0,
        "shell": "system",
        "line_height": "standard",
        "detect_venv": "off",
    },
    "lsp": {
        "rust-analyzer": {
            "check": {
                "command": "check",
            },
        },
        "cargo-tom": {
            "initialization_options": {
                /// Search
                "per_page": 25,
                /// What features should be displayed on hover
                /// All, UnusedOpt, Features,
                "feature_display_mode": "UnusedOpt",
                "hide_docs_info_message": false,
                /// Sort toml on format
                "sort_format": true,
                /// Use stable versions in completions
                "stable_version": true,
                /// Offline mode uses https://github.com/frederik-uni/crates.io-dump-minfied for search
                /// The order is non existent feel free to contribute
                "offline": false,
            },
        },
        "jdtls": {
            "settings": {
                "jdk_auto_download": true,
            },
        },
        "metals": {
            "settings": {
                "jdk_auto_download": true,
                "inlayHints": {
                    "inferredTypes": {
                        "enable": true,
                    },
                },
            },
        },
    },
}
