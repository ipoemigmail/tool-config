{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@seonggukchoi/opencode-claude-code-plugin"],
  "provider": {
    "kakao-ai-platform": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "kakao-ai-platform",
      "options": {
        //"baseURL": "https://api-inference-internal.kap.9rum.cc/v1",
        "baseURL": "http://localhost:8801/v1",
        "apiKey": "kap_7gQ2a3wwxkuXh89CRfFaFnuBRb3kZcinHB2ZElDAcrwok5lvTpnUcR9AdtAMSyOT"
      },
      "models": {
        "glm-5-fp8": {
          "name": "glm-5-fp8",
          "limit": {
            "context": 200000,
            "output": 128000
          }
        }
      }
    },
    "claude-code": {
      "npm": "@seonggukchoi/opencode-claude-code-provider",
      "models": {
        "sonnet": { "id": "claude-sonnet-4-6" },
        "opus": { "id": "claude-opus-4-6" },
        "haiku": { "id": "claude-haiku-4-5" }
      }
    }
  },
  "permission": {
    "external_directory": {
      "/private/tmp/**/*": "allow",
      "/private/tmp/*": "allow",
      "/tmp/**/*": "allow",
      "/tmp/*": "allow"
    }
  }
}
