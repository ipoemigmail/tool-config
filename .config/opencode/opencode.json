{
    "$schema": "https://opencode.ai/config.json",
    //"plugin": [
    //    "opencode-claude-auth",
    //    "opencode-antigravity-auth@latest"
    //],
    "plugin": [
        "@ex-machina/opencode-anthropic-auth",
        "opencode-antigravity-auth@latest"
    ],
    "disabled_providers": ["opencode-go"],
    "provider": {
        "openai": {
            "options": {
                "headerTimeout": 5000
            },
            "models": {
                "gpt-5.5": {
                    "limit": {
                        "context": 400000,
                        "input": 272000,
                        "output": 128000
                    }
                },
                "gpt-5.5-fast": {
                    "limit": {
                        "context": 400000,
                        "input": 272000,
                        "output": 128000
                    }
                },
                "gpt-5.4-mini": {
                    "limit": {
                        "context": 400000,
                        "input": 272000,
                        "output": 128000
                    }
                },
                "gpt-5.4-mini-fast": {
                    "limit": {
                        "context": 400000,
                        "input": 272000,
                        "output": 128000
                    }
                },
                "gpt-5.3-codex": {
                    "limit": {
                        "context": 400000,
                        "input": 272000,
                        "output": 128000
                    }
                }
            }
        },
        "opencode-go": {
            "models": {
                "deepseek-v4-pro": {
                    "limit": {
                        "context": 1048576,
                        "output": 1048576
                    }
                },
                "deepseek-v4-flash": {
                    "limit": {
                        "context": 1048576,
                        "output": 1048576
                    }
                }
            }
        },
        "kakao-ai-platform-proxy": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "kakao-ai-platform",
            "options": {
                "baseURL": "http://localhost:8801/v1",
                "apiKey": "kap_7gQ2a3wwxkuXh89CRfFaFnuBRb3kZcinHB2ZElDAcrwok5lvTpnUcR9AdtAMSyOT"
            },
            "models": {
                "glm-5-fp8": {
                    "name": "glm-5-fp8",
                    "limit": {
                        "context": 200000,
                        "output": 128000
                    }
                }
            }
        },
        "kakao-ai-platform": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "kakao-ai-platform",
            "options": {
                "baseURL": "https://api-inference-internal.kap.9rum.cc/v1",
                "apiKey": "kap_7gQ2a3wwxkuXh89CRfFaFnuBRb3kZcinHB2ZElDAcrwok5lvTpnUcR9AdtAMSyOT"
            },
            "models": {
                "qwen3-coder-480b-instruct": {
                    "limit": {
                        "context": 200000,
                        "output": 128000
                    }
                }
            }
        },
        "lm-studio": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "lm-studio",
            "options": {
                "baseURL": "http://127.0.0.1:1234/v1"
            },
            "models": {
                "gemma-4-26b-a4b-it": {
                    "name": "gemma-4-26b-a4b-it",
                    "limit": {
                        "context": 160000,
                        "output": 200000
                    }
                },
                "gemma-4-e4b-it": {
                    "name": "gemma-4-e4b-it",
                    "limit": {
                        "context": 128000,
                        "output": 200000
                    }
                }
            }
        },
        "amazon-bedrock": {
            "options": {
                "region": "ap-northeast-2",
                "endpoint": "https://llm-dashboard.onkakao.net/bedrock",
                "timeout": 1800000,
                "chunkTimeout": 1800000
            },
            "models": {
                "global.anthropic.claude-opus-4-8": {
                    "name": "Opus 4.8",
                    "limit": {
                        //"context": 1000000,
                        "context": 5120000,
                        "output": 128000
                    }
                },
                "global.anthropic.claude-opus-4-7": {
                    "name": "Opus 4.7",
                    "limit": {
                        //"context": 1000000,
                        "context": 5120000,
                        "output": 128000
                    }
                },
                "global.anthropic.claude-sonnet-4-6": {
                    "name": "Sonnet 4.6",
                    "limit": {
                        //"context": 1000000,
                        "context": 5120000,
                        "output": 64000
                    }
                },
                "global.anthropic.claude-haiku-4-5-20251001-v1:0": {
                    "name": "Haiku 4.5"
                }
            }
        }
    },
    "permission": {
        "external_directory": {
            "/private/tmp/**/*": "allow",
            "/private/tmp/*": "allow",
            "/tmp/**/*": "allow",
            "/tmp/*": "allow",
            "/**/tee/*": "allow"
        }
    }
}
