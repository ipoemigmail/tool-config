{
    "$schema": "https://opencode.ai/config.json",
    //"plugin": [
    //    "opencode-claude-auth",
    //    "opencode-antigravity-auth@latest"
    //],
    "plugin": [
        "@ex-machina/opencode-anthropic-auth",
        "opencode-antigravity-auth@latest"
    ],
    "provider": {
        "openai": {
            "models": {
                "gpt-5.5": {
                    "limit": {
                        "context": 512000,
                        "output": 128000
                    }
                }
            }
        },
        "anthropic": {
            "models": {
                "claude-opus-4-7": {
                    "limit": {
                        "context": 512000,
                        "output": 128000
                    }
                }
            }
        },
        "opencode-go": {
            "models": {
                "deepseek-v4-pro": {
                    "limit": {
                        "context": 512000,
                        "output": 384000
                    }
                },
                "deepseek-v4-flash": {
                    "limit": {
                        "context": 512000,
                        "output": 384000
                    }
                }
            }
        },
        "kakao-ai-platform-proxy": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "kakao-ai-platform",
            "options": {
                "baseURL": "http://localhost:8801/v1",
                "apiKey": "kap_7gQ2a3wwxkuXh89CRfFaFnuBRb3kZcinHB2ZElDAcrwok5lvTpnUcR9AdtAMSyOT"
            },
            "models": {
                "glm-5-fp8": {
                    "name": "glm-5-fp8",
                    "limit": {
                        "context": 200000,
                        "output": 128000
                    }
                }
            }
        },
        "kakao-ai-platform": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "kakao-ai-platform",
            "options": {
                "baseURL": "https://api-inference-internal.kap.9rum.cc/v1",
                "apiKey": "kap_7gQ2a3wwxkuXh89CRfFaFnuBRb3kZcinHB2ZElDAcrwok5lvTpnUcR9AdtAMSyOT"
            },
            "models": {
                "qwen3-coder-480b-instruct": {
                    "limit": {
                        "context": 200000,
                        "output": 128000
                    }
                }
            }
        },
        "lm-studio": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "lm-studio",
            "options": {
                "baseURL": "http://127.0.0.1:1234/v1"
            },
            "models": {
                "gemma-4-26b-a4b-it": {
                    "name": "gemma-4-26b-a4b-it",
                    "limit": {
                        "context": 160000,
                        "output": 200000
                    }
                },
                "gemma-4-e4b-it": {
                    "name": "gemma-4-e4b-it",
                    "limit": {
                        "context": 128000,
                        "output": 200000
                    }
                }
            }
        }
    },
    "permission": {
        "external_directory": {
            "/private/tmp/**/*": "allow",
            "/private/tmp/*": "allow",
            "/tmp/**/*": "allow",
            "/tmp/*": "allow"
        }
    }
}
