      },
      "researcher": {
        "model": "kakao-aws-bedrock/global.anthropic.claude-haiku-4-5-20251001-v1:0",
        "thinking": "medium"
      },
      "context-builder": {
        "model": "kakao-aws-bedrock/global.anthropic.claude-haiku-4-5-20251001-v1:0",
        "thinking": "medium"
      },
      "worker": {
        "model": "kakao-aws-bedrock/global.anthropic.claude-sonnet-4-6",
        "thinking": "medium"
      },
      "delegate": {
        "model": "kakao-aws-bedrock/global.anthropic.claude-sonnet-4-6"
      },
      "reviewer": {
        "model": "kakao-aws-bedrock/global.anthropic.claude-opus-4-8",
