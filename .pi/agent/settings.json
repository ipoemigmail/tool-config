{
  "lastChangelogVersion": "0.80.3",
  "theme": "dark",
  "defaultProvider": "kakao-aws-bedrock",
  "defaultModel": "global.anthropic.claude-opus-4-8",
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": false,
  "enabledModels": [
    "openai-codex/gpt-5.5",
    "openai-codex/gpt-5.4",
    "kakao-aws-bedrock/global.anthropic.claude-opus-4-8",
    "kakao-aws-bedrock/global.anthropic.claude-sonnet-4-6",
    "ollama-cloud/glm-5.2",
    "ollama-cloud/minimax-m3",
    "ollama-cloud/deepseek-v4-pro",
    "kap-inference/glm-5.2-fp8"
  ],
  "packages": [
    "npm:pi-web-access",
    "npm:pi-lens",
    "npm:pi-ollama-cloud",
    "npm:@entelligentsia/pi-claude-compat",
    "npm:pi-subagents",
    "npm:pi-intercom",
    "npm:pi-prompt-template-model"
  ],
  "gptConfig": {
    "fastMode": false,
    "personality": "none",
    "verbosity": "medium",
    "summary": "auto",
